{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orivanta.invalid/schemas/layer-manifest.schema.json",
  "title": "Orivanta Layer Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "version",
    "title",
    "description",
    "license",
    "attribution",
    "source",
    "data",
    "presentation",
    "accessibility",
    "limitations"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "url"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "attribution": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publisher",
        "dataset",
        "version",
        "scale",
        "url",
        "downloadUrl",
        "retrievedOn",
        "sha256"
      ],
      "properties": {
        "publisher": {
          "type": "string",
          "minLength": 1
        },
        "dataset": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "scale": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "downloadUrl": {
          "type": "string",
          "format": "uri"
        },
        "retrievedOn": {
          "type": "string",
          "format": "date"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "format",
        "geometryTypes",
        "featureCount",
        "bounds",
        "bytes",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "const": "GeoJSON"
        },
        "geometryTypes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "enum": [
              "Point",
              "MultiPoint",
              "LineString",
              "MultiLineString",
              "Polygon",
              "MultiPolygon"
            ]
          }
        },
        "featureCount": {
          "type": "integer",
          "minimum": 0
        },
        "bounds": {
          "type": "array",
          "description": "[west, south, east, north]",
          "prefixItems": [
            {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            },
            {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            },
            {
              "type": "number",
              "minimum": -180,
              "maximum": 180
            },
            {
              "type": "number",
              "minimum": -90,
              "maximum": 90
            }
          ],
          "minItems": 4,
          "maxItems": 4
        },
        "bytes": {
          "type": "integer",
          "minimum": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["defaultVisible", "minimumZoomProperty", "labelProperty"],
      "properties": {
        "defaultVisible": {
          "type": "boolean"
        },
        "minimumZoomProperty": {
          "type": "string",
          "minLength": 1
        },
        "labelProperty": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "accessibility": {
      "type": "object",
      "additionalProperties": false,
      "required": ["listLabel", "itemLabelTemplate", "descriptionProperty"],
      "properties": {
        "listLabel": {
          "type": "string",
          "minLength": 1
        },
        "itemLabelTemplate": {
          "type": "string",
          "minLength": 1
        },
        "descriptionProperty": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
