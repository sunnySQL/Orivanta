{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://orivanta.invalid/schemas/catalog.schema.json",
  "title": "Orivanta Data Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "layers"],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "layers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "version",
          "title",
          "description",
          "manifestPath",
          "defaultVisible"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "version": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "manifestPath": {
            "type": "string",
            "pattern": "^layers/.+/layer\\.json$"
          },
          "defaultVisible": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
